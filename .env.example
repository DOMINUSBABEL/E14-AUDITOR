# API Key for Gemini API (Can be set as GEMINI_API_KEY or API_KEY)
GEMINI_API_KEY=your_api_key_here
API_KEY=your_api_key_here

# AI Provider (gemini | openai)
VITE_AI_PROVIDER=gemini

# Optional: OpenAI Compatible Provider (e.g. Ollama)
VITE_OPENAI_BASE_URL=http://localhost:11434/v1
VITE_OPENAI_API_KEY=ollama
VITE_OPENAI_MODEL=qwen2-vl
